module(name = "rules_agentic_ide", version = "0.0.4")

bazel_dep(name = "platforms", version = "1.0.0")
bazel_dep(name = "bazel_skylib", version = "1.8.2")
bazel_dep(name = "rules_rust", version = "0.70.0")
bazel_dep(name = "rules_rdf", version = "0.3.0")
bazel_dep(name = "rules_jena", version = "0.3.2")

register_toolchains(
    "@rules_jena//jena:jena_sparql_toolchain_def",
    "@rules_jena//jena:jena_shacl_toolchain_def",
    "@rules_jena//jena:jena_riot_toolchain_def",
    "@rules_jena//jena:jena_reasoner_toolchain_def",
)

rust = use_extension("@rules_rust//rust:extensions.bzl", "rust")
rust.toolchain(edition = "2021", versions = ["1.95.0"])
use_repo(rust, "rust_toolchains")
register_toolchains("@rust_toolchains//:all")

crate = use_extension("@rules_rust//crate_universe:extension.bzl", "crate", isolate = True)
crate.spec(package = "anyhow", version = "1.0")
crate.spec(package = "serde_json", version = "1.0")
crate.spec(package = "sha2", version = "0.10")
crate.spec(features = ["derive"], package = "clap", version = "4.5")
crate.from_specs(name = "crates")
use_repo(crate, "crates")
