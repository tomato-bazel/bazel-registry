    name = "corpus_base64_encode_python_stdlib",
    urls = ["https://raw.githubusercontent.com/python/cpython/v3.12.7/Lib/base64.py"],
    sha256 = "8d1f608dbf030d11d6ec4df9e4c55b73fb68cdfbd9f53a7c91684a93b55564b5",
