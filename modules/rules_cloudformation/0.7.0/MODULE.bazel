# Bazel rules for AWS CloudFormation templates — schema-derived
# typed Bazel rules via rules_jsonschema. The schema source is the
# upstream Java assembler from `aws-cloudformation/cloudformation-
# template-schema`, run at build time against a sha-pinned snapshot
# of the AWS CloudFormation Resource Specification. The assembler
# sources are vendored (delomboked) under `cloudformation/private/
# assembler_src/`; see docs/SCHEMA_SOURCE.md for the trade-off.
module(
    name = "rules_cloudformation",
    version = "0.7.0",
)

bazel_dep(name = "platforms", version = "1.0.0")
bazel_dep(name = "bazel_skylib", version = "1.8.2")

# rules_jsonschema generates typed Bazel rules (one per AWS::*
# resource type) from the assembled CloudFormation JSON Schemas at
# build time. v0.3 added auto-kinds (--kinds-pointer-base + template
# flags) which we use to cover the whole spec instead of hand-
# enumerating service groups. See docs/SCHEMA_SOURCE.md.
bazel_dep(name = "rules_jsonschema", version = "0.3.0")

# rules_java compiles the vendored assembler sources. The
# linter (cfn-lint port) planned for v0.3+ will reuse this dep.
bazel_dep(name = "rules_java", version = "9.1.0")

# rules_jvm_external pins the assembler's Maven dependencies.
bazel_dep(name = "rules_jvm_external", version = "6.7")

# The assembler's Maven coordinates. Versions match the upstream
# pom.xml at the pinned commit (5d7815b1...), modulo the log4j-api
# co-pin (the upstream pom only lists log4j-core but log4j-api is
# the actual import). Lombok is not pinned because we vendor a
# delomboked copy of the sources.
maven = use_extension("@rules_jvm_external//:extensions.bzl", "maven")
maven.install(
    name = "cfn_assembler_maven",
    artifacts = [
        "org.apache.logging.log4j:log4j-core:2.17.1",
        "org.apache.logging.log4j:log4j-api:2.17.1",
        "com.fasterxml.jackson.core:jackson-databind:2.14.1",
        "com.fasterxml.jackson.core:jackson-core:2.14.1",
        "com.fasterxml.jackson.core:jackson-annotations:2.14.1",
        "com.fasterxml.jackson.dataformat:jackson-dataformat-yaml:2.14.1",
        "com.github.spullara.mustache.java:compiler:0.9.5",
        "args4j:args4j:2.33",
        "com.google.guava:guava:32.1.3-jre",
    ],
    lock_file = "//:maven_install.json",
    repositories = [
        "https://repo1.maven.org/maven2",
    ],
)
use_repo(maven, "cfn_assembler_maven")

# Fetch the pinned AWS CloudFormation Resource Specification
# snapshot.
cfn_sources = use_extension(
    "//cloudformation/private:extensions.bzl",
    "cfn_sources_extension",
)
use_repo(
    cfn_sources,
    "cfn_resource_spec",
    "cfn_endpoint_aws_s3_bucket",
)

# rules_python drives the docstring-overlay Python script
# (cloudformation/private/overlay_descriptions.py). Not a dev_dep
# because the codegen pipeline depends on it transitively.
bazel_dep(name = "rules_python", version = "1.7.0")

python = use_extension(
    "@rules_python//python/extensions:python.bzl",
    "python",
    dev_dependency = True,
)
python.toolchain(python_version = "3.12", is_default = True)

# rules_shell underpins the default aws CLI toolchain (a thin sh_binary
# around system `aws`) used by cloudformation_up / cloudformation_down.
bazel_dep(name = "rules_shell", version = "0.6.1")

# Default aws CLI toolchain — PATH-based sh wrapper. Consumers who
# need hermeticity can register their own toolchain (multitool,
# http_file, etc.) and Bazel's toolchain resolution will prefer it.
register_toolchains("//cloudformation/aws_cli:default_aws_cli_toolchain")

# Dev-only.
bazel_dep(name = "stardoc", version = "0.7.2", dev_dependency = True)
